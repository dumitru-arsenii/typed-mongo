{
  "name": "@typed-mongo/express",
  "version": "0.0.2",
  "private": false,
  "description": "Express middleware helpers for typed-mongo repositories.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "lint": "eslint src test --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@typed-mongo/core": "workspace:*"
  },
  "peerDependencies": {
    "express": ">=4.18 <6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
